{
    "name": "ententpay_v2",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "clean": "rm -rf dist",
        "copy": "cpy \"assets/**/*\" dist/assets",
        "html": "html-minifier-terser index.html -o dist/index.html --collapse-whitespace --remove-comments",
        "css": "cleancss -o dist/css/style.css css/style.css",
        "js": "terser js/main.js -o dist/js/main.js -c -m",
        "build": "npm run clean && run-p copy html css js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "clean-css-cli": "^5.6.3",
        "cpy-cli": "^7.0.0",
        "html-minifier-terser": "^7.2.0",
        "npm-run-all": "^4.1.5",
        "terser": "^5.46.1"
    }
}
